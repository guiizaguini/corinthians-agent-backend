{
  "name": "corinthians-agent-backend",
  "version": "2.0.0",
  "description": "SaaS multi-tenant: torcedores registram sua presença em jogos e acompanham estatísticas pessoais.",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "migrate:v2": "node scripts/migrate_v2.js",
    "migrate:v2:from-legacy": "node scripts/migrate_v2.js from-legacy",
    "migrate": "node scripts/migrate.js",
