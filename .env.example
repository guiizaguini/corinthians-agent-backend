# ==========================================================
# Postgres (Railway injeta automaticamente)
# ==========================================================
DATABASE_URL=postgres://user:pass@host:5432/dbname

# ==========================================================
# v2 SaaS — obrigatórios
# ==========================================================

# Segredo pra assinar JWTs. Gere com:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=troque-por-uma-string-aleatoria-de-pelo-menos-32-chars

# Tempo de vida do token (default 30d)
# JWT_EXPIRES_IN=30d

# ==========================================================
# Seed da migração from-legacy (só necessário quando
# roda `npm run migrate:v2:from-legacy` pra criar o user
# principal a partir dos jogos legados)
# ==========================================================
SEED_USER_EMAIL=guilhermezaguini@gmail.com
SEED_USER_PASSWORD=defina-uma-senha-forte-aqui
SEED_USER_NAME=Guilherme Zaguini

# ==========================================================
# v1 legado (MCP Agent da Botmaker)
# ==========================================================
API_KEY=troque-isso-por-uma-string-longa-e-aleatoria

# ==========================================================
# Runtime
# ==========================================================
PORT=3000
LOG_QUERIES=0
