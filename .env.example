# Fornecido automaticamente pelo Railway ao provisionar Postgres
DATABASE_URL=postgres://user:pass@host:5432/dbname

# API key que o MCP Agent da Botmaker deve mandar em x-api-key
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=troque-isso-por-uma-string-longa-e-aleatoria

# Porta (Railway injeta automaticamente, default 3000 em dev)
PORT=3000

# Opcional: 1 para logar queries
LOG_QUERIES=0
